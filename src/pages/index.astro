---
import Hero from '../components/Hero';
import Navbar from '../components/Navbar.astro';
import LayananUtama from '../components/LayananUtama';
import PaketAqiqah from '../components/PaketAqiqah';
import PaketSyukuran from '../components/PaketSyukuran';
import MenuMasakan from '../components/MenuMasakan';
import KelengkapanLayanan from '../components/KelengkapanLayanan';
import SertifikasiHalal from '../components/SertifikasiHalal';
import ProsesPemesanan from '../components/ProsesPemesanan';
import WilayahLayanan from '../components/WilayahLayanan';
import Testimonial from '../components/Testimonial';
import FAQ from '../components/FAQ';
import BookingCTA from '../components/BookingCTA';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Berkah Catering — Katering Aqiqah & Syukuran Halal</title>
    <meta name="description" content="Katering aqiqah & syukuran halal. Kambing pilihan, penyembelihan syar'i, masak fresh hari H. Konsultasi gratis." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar />
    <Hero client:load />
    <LayananUtama client:visible />
    <PaketAqiqah client:visible />
    <PaketSyukuran client:visible />
    <MenuMasakan client:visible />
    <KelengkapanLayanan client:visible />
    <SertifikasiHalal client:visible />
    <ProsesPemesanan client:visible />
    <WilayahLayanan client:visible />
    <Testimonial client:visible />
    <FAQ client:visible />
    <BookingCTA client:idle />
    <Footer />
  </body>
</html>
